sources:
  superpowers:
    repo: https://github.com/example/skills.git
    # First version supports plain branch names only, such as main or feature/foo.
    ref: main
    skills:
      brainstorming:
        path: skills/brainstorming
      writing-plans:
        path: skills/writing-plans

profiles:
  trae-workspace:
    # Agent skills directory that receives dist/<skill> during sync.
    target: /cloudide/workspace/.trae/skills
    skills:
      - brainstorming
      - writing-plans
